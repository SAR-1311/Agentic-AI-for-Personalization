# --------------------------------------------------------------------------
# LLM Provider — choose one and fill the matching key
# --------------------------------------------------------------------------
LLM_PROVIDER=openai            # openai | anthropic | ollama | huggingface

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (local, alternative)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Hugging Face Inference (alternative)
HF_API_TOKEN=
HF_MODEL=meta-llama/Llama-3.2-3B-Instruct

# --------------------------------------------------------------------------
# Reasoning Gatekeeper — Eq. 1: I(m) = α·f(m) + β·c(m) + γ·e(m)
# --------------------------------------------------------------------------
WEIGHT_FREQUENCY=0.3
WEIGHT_CONFIDENCE=0.4
WEIGHT_EMOTION=0.3
IMPORTANCE_THRESHOLD=0.35      # below this, treat as noise & discard

# --------------------------------------------------------------------------
# Controlled Forgetting — Eq. 7: I_t(m) = I_0(m) · e^(-λt)
# --------------------------------------------------------------------------
DECAY_LAMBDA=0.05              # tune during evaluation
DECAY_INTERVAL_HOURS=24
FORGET_FLOOR=0.05              # soft-delete below this score

# --------------------------------------------------------------------------
# Memory hierarchy
# --------------------------------------------------------------------------
ACTIVE_CONTEXT_SIZE=20
RETRIEVAL_TOP_K=5
RETRIEVAL_SIM_WEIGHT=0.6       # cosine weight in retrieval ranking
RETRIEVAL_IMP_WEIGHT=0.4       # importance weight in retrieval ranking

# --------------------------------------------------------------------------
# Storage
# --------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_PATH=./data/persona.db

# --------------------------------------------------------------------------
# App
# --------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
